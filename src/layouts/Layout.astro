---
import '../styles/global.css';
import CodeRain from '../components/CodeRain.astro';

interface Props {
  title?: string;
}

const { title = 'Efe/@skyline69' } = Astro.props;
const isProduction: boolean = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Efe's developer portfolio — projects, tech stack, and more." />
    <link rel="preload" href="/fonts/fira-code/FiraCode-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fira-code/FiraCode-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Atkinson_Hyperlegible/AtkinsonHyperlegible-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Efe's developer portfolio — projects, tech stack, and more." />
    <meta property="og:url" content="https://dasguney.dev" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Efe's developer portfolio — projects, tech stack, and more." />
    {isProduction && (
      <Fragment>
        <link rel="dns-prefetch" href="https://analytics.dasguney.com" />
        <link rel="preconnect" href="https://analytics.dasguney.com" crossorigin />
        <script
          is:inline
          defer
          fetchpriority="low"
          src="https://analytics.dasguney.com/script.js"
          data-website-id="80596796-dd36-4627-a4c8-5215c41378cd"
        ></script>
      </Fragment>
    )}
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <CodeRain />
    <slot />
  </body>
</html>
