---
import '../styles/global.css';
import CodeRain from '../components/CodeRain.astro';

interface Props {
  title?: string;
}

const { title = 'Efe — Developer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Efe's developer portfolio — projects, tech stack, and more." />
    <title>{title}</title>
  </head>
  <body>
    <CodeRain />
    <slot />
  </body>
</html>
