---
import TypingText from './TypingText.astro';
import { Icon } from 'astro-icon/components';

/**
 * Build rows of random code-like characters that tile the hero background.
 * Two identical blocks stacked — the animation scrolls one block height
 * then resets seamlessly for an infinite upward scroll.
 *
 * 200 chars/row at small font + letter-spacing guarantees full-width
 * coverage on any viewport. 40 rows gives enough height for the scroll
 * to loop without visible gaps.
 */
const glyphs = '01{}[]<>/\\|;:=+-._#@&*~$%?!^abcdef0123456789ABCDEF';
const cols = 200;
const rows = 40;

function randomChar(): string {
  return Math.random() < 0.35
    ? '\u00A0'  // non-breaking space for breathing room
    : glyphs[Math.floor(Math.random() * glyphs.length)];
}

const lines: string[] = [];
for (let r = 0; r < rows; r++) {
  let line = '';
  for (let c = 0; c < cols; c++) {
    line += randomChar();
  }
  lines.push(line);
}
const block = lines.join('\n');
---

<section class="hero">
  <!-- Scrolling character field -->
  <div class="char-field" aria-hidden="true">
    <div class="char-scroll">
      <pre class="char-block">{block}</pre>
      <pre class="char-block">{block}</pre>
    </div>
  </div>

  <!-- Grain texture -->
  <svg aria-hidden="true" style="position:absolute;width:0;height:0;">
    <filter id="grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
  </svg>
  <div class="grain-overlay" aria-hidden="true"></div>

  <!-- Foreground content -->
  <div class="container hero-content">
    <p class="greeting">Hello, I'm</p>
    <h1>Efe</h1>
    <div class="strapline">
      <TypingText
        texts={[
          'Developer.',
          'Tinkerer.',
          'Music lover.',
          'Lifelong learner.',
        ]}
        loop={true}
        speed={45}
        pauseMs={1200}
      />
    </div>
  </div>

  <!-- Scroll-down indicator -->
  <a href="#about" class="scroll-down" aria-label="Scroll down to content">
    <span class="chevron" aria-hidden="true">
      <Icon name="lucide:chevron-down" size={24} />
    </span>
  </a>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  /* ── Scrolling character field ── */

  .char-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .char-scroll {
    animation: scroll-chars 50s linear infinite;
  }

  .char-block {
    font-family: var(--font);
    font-size: 0.75rem;
    line-height: 2.4;
    letter-spacing: 0.3em;
    color: var(--accent);
    opacity: 0.035;
    margin: 0;
    padding: 0;
    white-space: pre;
    user-select: none;
  }

  @keyframes scroll-chars {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .char-scroll {
      animation: none;
    }
    .char-block {
      opacity: 0.025;
    }
  }

  /* ── Grain overlay ── */

  .grain-overlay {
    position: absolute;
    inset: -50%;
    width: 200%;
    height: 200%;
    filter: url(#grain);
    opacity: 0.05;
    pointer-events: none;
    z-index: 1;
    animation: grain-drift 8s steps(10) infinite;
  }

  @keyframes grain-drift {
    0%, 100% { transform: translate(0, 0); }
    10% { transform: translate(-2%, -3%); }
    20% { transform: translate(3%, 1%); }
    30% { transform: translate(-1%, 4%); }
    40% { transform: translate(4%, -2%); }
    50% { transform: translate(-3%, 2%); }
    60% { transform: translate(2%, -4%); }
    70% { transform: translate(-4%, 1%); }
    80% { transform: translate(1%, 3%); }
    90% { transform: translate(3%, -1%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .grain-overlay {
      animation: none;
    }
  }

  /* ── Hero content ── */

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .greeting {
    font-size: 1.1rem;
    color: var(--accent);
    opacity: 0.8;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .strapline {
    font-size: 1.35rem;
    color: var(--accent);
    min-height: 2rem;
  }

  /* ── Scroll-down indicator ── */

  .scroll-down {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }

  .chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    color: var(--highlight);
    opacity: 0.5;
    animation: bounce-down 2s ease-in-out infinite;
  }

  .chevron :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .scroll-down:hover .chevron {
    opacity: 1;
  }

  @keyframes bounce-down {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .chevron {
      animation: none;
    }
  }

  @media (max-width: 768px) {
    .strapline {
      font-size: 1rem;
    }

    .greeting {
      font-size: 0.9rem;
    }

    .scroll-down {
      bottom: 1.5rem;
    }
  }
</style>
