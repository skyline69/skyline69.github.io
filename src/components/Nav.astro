---
interface NavLink {
  label: string;
  href: string;
}

const links: NavLink[] = [
  { label: 'About & Highlights', href: '#about' },
  { label: 'Tech', href: '#techstack' },
  { label: 'Projects', href: '#projects' },
];
---

<nav class="site-nav" id="site-nav">
  <div class="nav-inner">
    <a href="#" class="nav-logo">Efe</a>
    <ul class="nav-links">
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li>
        <a
          href="https://github.com/skyline69"
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link-github"
        >
          GitHub
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  function initNav(): void {
    const nav: HTMLElement | null = document.getElementById('site-nav');
    if (!nav) return;
    if (nav.dataset.navInitialized === 'true') return;
    nav.dataset.navInitialized = 'true';

    // ── Solid background on scroll ──

    let ticking: boolean = false;

    function onScroll(): void {
      if (!ticking) {
        requestAnimationFrame((): void => {
          if (window.scrollY > 80) {
            nav!.classList.add('nav--solid');
          } else {
            nav!.classList.remove('nav--solid');
          }
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ── Active link highlighting via scroll position ──

    const navLinks: NodeListOf<HTMLAnchorElement> =
      nav.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"]');

    // Build list of { id, link } pairs from nav anchors
    interface NavTarget {
      id: string;
      link: HTMLAnchorElement;
    }

    const targets: NavTarget[] = [];
    navLinks.forEach((link: HTMLAnchorElement): void => {
      const href: string | null = link.getAttribute('href');
      if (href) {
        targets.push({ id: href.replace('#', ''), link });
      }
    });

    // Detection line: 25% from the top of the viewport
    const DETECTION_RATIO: number = 0.25;

    // Tolerance for treating sections as same-row (in pixels)
    const ROW_TOLERANCE: number = 10;

    let activeTicking: boolean = false;
    let currentActiveId: string = '';

    interface SectionInfo {
      id: string;
      link: HTMLAnchorElement;
      top: number;
      bottom: number;
      left: number;
    }

    interface SectionRow {
      top: number;
      bottom: number;
      sections: SectionInfo[];
    }

    function setActiveLink(activeLink: HTMLAnchorElement | null): void {
      navLinks.forEach((link: HTMLAnchorElement): void => {
        link.classList.remove('nav-active');
      });

      if (activeLink) {
        activeLink.classList.add('nav-active');
        const href: string | null = activeLink.getAttribute('href');
        currentActiveId = href ? href.replace('#', '') : '';
      } else {
        currentActiveId = '';
      }
    }

    function getSections(): SectionInfo[] {
      const sections: SectionInfo[] = [];
      for (const target of targets) {
        const el: HTMLElement | null = document.getElementById(target.id);
        if (!el) continue;
        const rect: DOMRect = el.getBoundingClientRect();
        sections.push({
          id: target.id,
          link: target.link,
          top: rect.top + window.scrollY,
          bottom: rect.bottom + window.scrollY,
          left: rect.left,
        });
      }

      sections.sort((a: SectionInfo, b: SectionInfo): number => {
        const verticalDelta: number = a.top - b.top;
        if (Math.abs(verticalDelta) <= ROW_TOLERANCE) {
          return a.left - b.left;
        }
        return verticalDelta;
      });

      return sections;
    }

    function groupSectionsByRow(sections: SectionInfo[]): SectionRow[] {
      const rows: SectionRow[] = [];

      for (const section of sections) {
        const lastRow: SectionRow | undefined = rows[rows.length - 1];
        if (!lastRow || Math.abs(section.top - lastRow.top) > ROW_TOLERANCE) {
          rows.push({
            top: section.top,
            bottom: section.bottom,
            sections: [section],
          });
          continue;
        }

        lastRow.sections.push(section);
        lastRow.bottom = Math.max(lastRow.bottom, section.bottom);
      }

      return rows;
    }

    function updateActiveLink(): void {
      const detectionLine: number = window.scrollY + window.innerHeight * DETECTION_RATIO;
      const sections: SectionInfo[] = getSections();
      if (sections.length === 0) {
        setActiveLink(null);
        return;
      }

      const rows: SectionRow[] = groupSectionsByRow(sections);
      let activeRow: SectionRow | null = null;

      for (const row of rows) {
        if (row.top <= detectionLine + ROW_TOLERANCE) {
          activeRow = row;
        }
      }

      if (!activeRow) {
        setActiveLink(null);
        return;
      }

      // For same-row sections, scroll position cannot distinguish left/right.
      // Prefer explicit hash intent, then preserve current active in-row.
      const hashId: string = window.location.hash.replace('#', '');
      if (hashId) {
        const hashSection: SectionInfo | undefined = activeRow.sections.find(
          (section: SectionInfo): boolean => section.id === hashId,
        );
        if (hashSection) {
          setActiveLink(hashSection.link);
          return;
        }
      }

      const currentSection: SectionInfo | undefined = activeRow.sections.find(
        (section: SectionInfo): boolean => section.id === currentActiveId,
      );
      if (currentSection) {
        setActiveLink(currentSection.link);
        return;
      }

      setActiveLink(activeRow.sections[0]?.link ?? null);
    }

    function onActiveScroll(): void {
      if (!activeTicking) {
        requestAnimationFrame((): void => {
          updateActiveLink();
          activeTicking = false;
        });
        activeTicking = true;
      }
    }

    navLinks.forEach((link: HTMLAnchorElement): void => {
      link.addEventListener('click', (): void => {
        setActiveLink(link);
      });
    });

    window.addEventListener('scroll', onActiveScroll, { passive: true });
    window.addEventListener('resize', onActiveScroll);
    window.addEventListener('hashchange', updateActiveLink);
    updateActiveLink();
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem 0;
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: blur(0px);
    transition:
      background 320ms ease,
      border-bottom-color 320ms ease,
      backdrop-filter 320ms ease;
  }

  .site-nav.nav--solid {
    background: color-mix(in srgb, var(--bg-alt) 80%, transparent);
    border-bottom-color: color-mix(in srgb, var(--accent) 10%, transparent);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gap);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--highlight);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .nav-logo:hover {
    color: var(--text);
  }

  .nav-logo:focus-visible {
    outline: 2px solid var(--highlight);
    outline-offset: 2px;
    color: var(--text);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--dim);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a:focus-visible {
    outline: 2px solid var(--highlight);
    outline-offset: 2px;
    color: var(--text);
  }

  .nav-links a.nav-active {
    color: var(--highlight);
  }

  .nav-links a.nav-link-github {
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 26%, transparent);
    padding: 0.2rem 0.45rem;
  }

  .nav-links a.nav-link-github:hover {
    color: var(--highlight);
    border-color: color-mix(in srgb, var(--highlight) 72%, transparent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .nav-links a.nav-link-github:focus-visible {
    outline: 2px solid var(--highlight);
    outline-offset: 2px;
    color: var(--highlight);
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1.25rem;
    }

    .nav-links a {
      font-size: 0.74rem;
      letter-spacing: 0.05em;
    }
  }

  @media (max-width: 480px) {
    .nav-links {
      gap: 0.75rem;
    }

    .nav-links a {
      font-size: 0.68rem;
      letter-spacing: 0.04em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav {
      transition: none;
    }
  }
</style>
