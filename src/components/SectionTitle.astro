---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="section-title">
  <h2>{text}</h2>
  <div class="separator" aria-hidden="true"></div>
</div>

<style>
  .section-title {
    margin-bottom: 2.5rem;
  }

  .section-title h2 {
    color: var(--text);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .separator {
    margin-top: 0.75rem;
    width: 3.5rem;
    height: 3px;
    background: var(--highlight);
    opacity: 0.7;
    user-select: none;
  }
</style>
