---
/**
 * TypingText.astro
 *
 * Lightweight typing animation component.
 * Props:
 *  - texts: string[]        — phrases to cycle through (or single phrase)
 *  - loop: boolean           — whether to loop through phrases (default false = one-pass)
 *  - class: string           — additional CSS class
 *  - speed: number           — ms per character (default 70)
 *  - pauseMs: number         — pause at full text before deleting (default 1500)
 */
interface Props {
  texts: string[];
  loop?: boolean;
  class?: string;
  speed?: number;
  pauseMs?: number;
}

const {
  texts,
  loop = false,
  class: className = '',
  speed = 70,
  pauseMs = 1500,
} = Astro.props;
---

<span
  class:list={['typing-cursor', className]}
  data-texts={JSON.stringify(texts)}
  data-loop={loop.toString()}
  data-speed={speed.toString()}
  data-pause={pauseMs.toString()}
  aria-label={texts[0]}
>{texts[0]}</span>

<script>
  // ── Active timer IDs for cleanup ──
  let activeTimers: number[] = [];

  function initTyping(): void {
    document.querySelectorAll<HTMLElement>('[data-texts]').forEach((el: HTMLElement): void => {
      if (el.dataset.initialized) return;
      el.dataset.initialized = 'true';

      const prefersReducedMotion: boolean = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      ).matches;

      if (prefersReducedMotion) return; // text already in DOM, do nothing

      const texts: string[] = JSON.parse(el.dataset.texts || '[]');
      const loop: boolean = el.dataset.loop === 'true';
      const speed: number = parseInt(el.dataset.speed || '70', 10);
      const pauseMs: number = parseInt(el.dataset.pause || '1500', 10);

      if (texts.length === 0) return;

      let phraseIndex: number = 0;
      let charIndex: number = 0;
      let isDeleting: boolean = false;
      let isVisible: boolean = true;
      let pendingTick: boolean = false;
      let destroyed: boolean = false;

      el.textContent = '';

      // ── Pause animation when off-screen ──
      const observer: IntersectionObserver = new IntersectionObserver(
        (entries: IntersectionObserverEntry[]): void => {
          isVisible = entries[0]?.isIntersecting ?? true;
          if (isVisible && pendingTick) {
            pendingTick = false;
            scheduleTick(speed);
          }
        },
        { threshold: 0 },
      );
      observer.observe(el);

      function scheduleTick(delay: number): void {
        const id: number = window.setTimeout(tick, delay);
        activeTimers.push(id);
      }

      function tick(): void {
        if (destroyed) return;

        if (!isVisible) {
          pendingTick = true;
          return;
        }

        const current: string = texts[phraseIndex];

        if (!isDeleting) {
          // Typing forward
          charIndex++;
          el.textContent = current.slice(0, charIndex);

          if (charIndex === current.length) {
            if (!loop && phraseIndex === texts.length - 1) {
              // Done — one pass, last phrase complete
              observer.disconnect();
              return;
            }
            // Pause then start deleting
            const id: number = window.setTimeout((): void => {
              if (destroyed) return;
              isDeleting = true;
              tick();
            }, pauseMs);
            activeTimers.push(id);
            return;
          }
        } else {
          // Deleting
          charIndex--;
          el.textContent = current.slice(0, charIndex);

          if (charIndex === 0) {
            isDeleting = false;
            phraseIndex = (phraseIndex + 1) % texts.length;
          }
        }

        const delay: number = isDeleting ? speed / 2 : speed;
        scheduleTick(delay);
      }

      // Start after a short delay to let the page settle
      scheduleTick(400);

      // Cleanup on page navigation (view transitions)
      document.addEventListener('astro:before-swap', (): void => {
        destroyed = true;
        observer.disconnect();
        for (const id of activeTimers) {
          clearTimeout(id);
        }
        activeTimers = [];
      }, { once: true });
    });
  }

  // Run on initial load and on Astro view transitions
  initTyping();
  document.addEventListener('astro:after-swap', initTyping);
</script>
